# Server-side only — never exposed to the PWA client.
ANTHROPIC_API_KEY=
# Optional override; defaults to Haiku for cheap parsing/matching calls
CLAUDE_MODEL=

# Kroger developer credentials (developer.kroger.com) — used by the Kroger adapter
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# Turso database (app.turso.tech) — get these from the database's own page,
# not Settings > API Tokens (that's a different, platform-level token).
# Note the hostname includes a region segment, e.g.:
#   libsql://<db-name>-<org-slug>.<region>.turso.io
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Single-password site gate ("just me" access, no user accounts yet).
# SITE_PASSWORD is yours to pick. SESSION_SECRET should be a long random
# string (not a password you'll type) — generate one, don't reuse it elsewhere.
SITE_PASSWORD=
SESSION_SECRET=
